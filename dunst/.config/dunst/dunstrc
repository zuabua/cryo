[global]
    monitor = 0
    follow = mouse
    width = 380
    height = 140
    origin = top-right
    offset = 14x54
    notification_limit = 4

    progress_bar = true
    progress_bar_height = 6
    progress_bar_frame_width = 0
    progress_bar_min_width = 220
    progress_bar_max_width = 360
    progress_bar_corner_radius = 3

    transparency = 15
    separator_height = 0
    padding = 14
    horizontal_padding = 16
    text_icon_padding = 12
    frame_width = 1
    gap_size = 8
    corner_radius = 14

    font = JetBrainsMono Nerd Font Mono 10
    line_height = 6
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    word_wrap = yes
    ellipsize = middle
    show_age_threshold = 60
    ignore_newline = no

    sort = yes
    idle_threshold = 120
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    icon_position = left
    min_icon_size = 32
    max_icon_size = 48
    icon_corner_radius = 8
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#292c3c"
    foreground = "#a5adce"
    frame_color = "#414559"
    highlight = "#a5adce"
    timeout = 4

[urgency_normal]
    background = "#292c3c"
    foreground = "#c6d0f5"
    frame_color = "#5eead4"
    highlight = "#5eead4"
    timeout = 6

[urgency_critical]
    background = "#292c3c"
    foreground = "#c6d0f5"
    frame_color = "#f87171"
    highlight = "#f87171"
    timeout = 0
